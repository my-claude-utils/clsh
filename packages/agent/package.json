{
  "name": "@clsh/agent",
  "version": "0.0.9",
  "description": "clsh local agent — PTY manager, WebSocket server, auth, and ngrok tunnel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cshumac/clsh.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/cshumac/clsh",
  "bugs": {
    "url": "https://github.com/cshumac/clsh/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clsh/shared": "0.0.1",
    "@ngrok/ngrok": "^1.4.0",
    "better-sqlite3": "11.0.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "jose": "^5.9.0",
    "node-pty": "1.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.0"
  }
}
